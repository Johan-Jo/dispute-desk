{
  "name": "disputedesk",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"try { require('fs').rmSync('.next', { recursive: true, force: true }); } catch (e) {}\" && next dev",
    "shopify:dev": "node -e \"require('dotenv').config({ path: '.env.local' }); const cid = process.env.SHOPIFY_API_KEY; if (!cid) throw new Error('SHOPIFY_API_KEY missing in .env.local'); require('child_process').execSync('npx shopify app dev --client-id ' + cid, { stdio: 'inherit', shell: true });\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.0.0",
    "@shopify/polaris": "^13.0.0",
    "@shopify/shopify-api": "^11.0.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.45.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "next": "^15.0.0",
    "next-intl": "^4.8.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.24",
    "dotenv": "^17.3.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "pg": "^8.18.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
