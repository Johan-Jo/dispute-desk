# ── Shopify ──────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_orders,read_shopify_payments_disputes,read_shopify_payments_dispute_evidences,write_shopify_payments_dispute_evidences
SHOPIFY_APP_URL=https://your-app.vercel.app

# Pin GraphQL Admin API version (default 2026-01)
SHOPIFY_API_VERSION=2026-01

# Real dispute generator (npm run seed:real-disputes). Uses SHOPIFY_API_KEY + SHOPIFY_API_SECRET (same as app) for tagging if SHOPIFY_ADMIN_TOKEN not set.
# SHOPIFY_STOREFRONT_DOMAIN=https://your-store.myshopify.com
# SHOPIFY_PAYMENTS_TEST_MODE_ACK=true
# STOREFRONT_PASSWORD=
# USE_SYSTEM_CHROME: script prefers installed Chrome by default; set false to force bundled Chromium

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Auth → URL Configuration: add redirect URLs for Supabase Auth (Dashboard), e.g.:
#   {SHOPIFY_APP_URL}/auth/open-in-shopify   — post “Continue with Shopify” OAuth (magic link / action_link landing)
# Migrations: primary path is Supabase CLI (`npm run db:migrate` = `npx supabase db push` after `supabase login` + `supabase link`). No extra env vars needed beyond SUPABASE_* above.
# Optional — only for `npm run db:migrate:script` (Node script + `_migrations` table) if you cannot use the CLI:
# SUPABASE_URL_POSTGRES=postgresql://postgres:YOUR_PASSWORD@db.<project-ref>.supabase.co:5432/postgres
# SUPABASE_DB_PASSWORD=

# ── Token Encryption (AES-256-GCM) ─────────────────────
# V1 key (hex-encoded 32-byte key). Add V2, V3… for rotation.
TOKEN_ENCRYPTION_KEY_V1=
# Backward-compat alias — points to same value as V1
TOKEN_ENCRYPTION_KEY=${TOKEN_ENCRYPTION_KEY_V1}

# ── Admin (optional) ────────────────────────────────────
# Password for /admin login. If unset, admin routes may reject.
# ADMIN_SECRET=

# ── Jobs / Cron ─────────────────────────────────────────
# Shared secret for cron routes (/api/jobs/worker, /api/cron/*). Generate with openssl rand -hex 32;
# set the same value in Vercel env so scheduled crons authenticate (Authorization: Bearer).
CRON_SECRET=

# ── E2E Tests (Playwright) ──────────────────────────────
# Portal sign-in for E2E tests. User must have at least one connected shop.
# E2E_TEST_EMAIL=
# E2E_TEST_PASSWORD=

# ── Email (Resend) ──────────────────────────────────────
# Required to send transactional emails (welcome, Resources Hub autopilot publish notifications, etc.). Use a verified domain in production.
# Autopilot “notification email” is configured in Admin → Resources → Settings (cms_settings), not here.
RESEND_API_KEY=
# From address. Use verified sending subdomain (mail.disputedesk.app). Override if needed.
# Default in code: DisputeDesk <notifications@mail.disputedesk.app>
EMAIL_FROM=DisputeDesk <notifications@mail.disputedesk.app>

# ── App URL (for email links, sitemap, SEO) ─────────────
# Public marketing site — set on every Vercel environment so emails never use a preview *.vercel.app host.
# NEXT_PUBLIC_APP_URL=https://disputedesk.app
# Optional server-only duplicate for transactional emails if NEXT_PUBLIC is unset:
# PUBLIC_CANONICAL_URL=https://disputedesk.app

# ── AI Content Generation ──────────────────────────────────
# OPENAI_API_KEY=sk-...
# GENERATION_MODEL=gpt-4o          # Optional, defaults to gpt-4o
# GENERATION_ENABLED=true          # Feature flag, defaults to false

# ── SEO / IndexNow ──────────────────────────────────────
# Random 8-128 char string for IndexNow verification. Enables instant indexing on Bing/Yandex/Seznam.
# INDEXNOW_KEY=your-random-key-here

# ── Observability ────────────────────────────────────────
# SENTRY_DSN=
# LOG_LEVEL=info
